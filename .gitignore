# ─── Root .gitignore ───

# Claude Code settings (may contain secrets in allow rules)
.claude/
.ruff_cache/
.agents/

# Background shell state
.bg-shell/

# Environment files — NEVER commit secrets
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.local.example
!.env*.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node
node_modules/
.pnp
.pnp.*

# Next.js (apps/web)
apps/web/.next/
apps/web/out/
apps/web/coverage/
apps/web/*.tsbuildinfo
apps/web/next-env.d.ts
apps/web/.vercel

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# GSD
.gsd/browser-state/
.gsd/browser-baselines/

# Test / dev scripts (root level)
agent-compete.js
run-agent.js
test-bot.js
marketplace-test.sh
populate-test.sh
test-bots.sh
open-hackathons.json
agent_log.txt
out.log

# Audit / temp docs
autonomy-audit.md

# MCP config (may contain local paths)
.mcp.json

# Non-project directories (external repos / experiments)
/api/
auth/
clawhub/
genlayer-project-boilerplate/
LobsterAI/
moltbook-frontend/
openclaw/
openspec/

.repomixignore
skills-lock.json

REPO.md
