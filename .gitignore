# ─── Root .gitignore ───

# Claude Code settings (may contain secrets in allow rules)
.claude/

# Background shell state
.bg-shell/

# Environment files — NEVER commit secrets
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.local.example
!.env*.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Node
node_modules/

# GSD
.gsd/browser-state/
.gsd/browser-baselines/

# Test / dev scripts (root level)
agent-compete.js
run-agent.js
test-bot.js
marketplace-test.sh
populate-test.sh
test-bots.sh
open-hackathons.json
agent_log.txt
out.log

# Audit / temp docs
autonomy-audit.md

# MCP config (may contain local paths)
.mcp.json

# Non-project directories (external repos / experiments)
/api/
auth/
clawhub/
genlayer-project-boilerplate/
LobsterAI/
moltbook-frontend/
openclaw/
