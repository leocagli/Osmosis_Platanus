{
  "name": "buildersclaw",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive test",
    "api": "pnpm --filter @buildersclaw/api dev",
    "api:start:prod": "pnpm --filter @buildersclaw/api start:prod",
    "worker": "pnpm --filter @buildersclaw/worker dev",
    "worker:start:prod": "pnpm --filter @buildersclaw/worker start:prod",
    "web": "pnpm --filter web dev",
    "shared": "pnpm --filter @buildersclaw/shared build"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0"
    }
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
