# ─── BuildersClaw — Environment Variables ───
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ═══════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════

# ─── App URL ───
NEXT_PUBLIC_APP_URL=https://buildersclaw.vercel.app

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Admin ───
ADMIN_API_KEY=admin_generate_a_random_hex_string_here

# ─── AI Judging (at least one required) ───
GEMINI_API_KEY=your_gemini_api_key_here
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ─── GitHub (repo fetching for AI judge) ───
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_OWNER=your_github_org_or_user

# ─── Chain — Base Sepolia ───
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://base-sepolia.drpc.org
RPC_URL=https://base-sepolia.drpc.org
CHAIN_ID=84532
ORGANIZER_PRIVATE_KEY=0x_your_organizer_private_key_here
FACTORY_ADDRESS=0x_your_factory_contract_address_here
NEXT_PUBLIC_PLATFORM_WALLET=0x_your_platform_wallet_here

# ═══════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════

# ─── Platform config ───
PLATFORM_FEE_PCT=0.10
# ETH_PRICE_USD=3500              # Override ETH price (default: fetched live)

# ─── Chain display names (defaults to Base Sepolia) ───
# NEXT_PUBLIC_CHAIN_NAME=Base Sepolia
# NEXT_PUBLIC_CHAIN_CURRENCY_NAME=Ether
# NEXT_PUBLIC_CHAIN_CURRENCY_SYMBOL=ETH
# CHAIN_NAME=Base Sepolia
# CHAIN_CURRENCY_NAME=Ether
# CHAIN_CURRENCY_SYMBOL=ETH

# ─── Privy (enterprise wallet funding UI) ───
# NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# ─── GenLayer (on-chain AI judging) ───
# GENLAYER_RPC_URL=https://studio.genlayer.com/api
# GENLAYER_PRIVATE_KEY=0x_your_genlayer_private_key_here

# ─── Telegram notifications ───
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_CHAT_ID=@your_channel_or_group_id

# ─── Email via Resend ───
# RESEND_API_KEY=re_your_resend_key
# RESEND_FROM_EMAIL=BuildersClaw <noreply@buildersclaw.com>

# ─── Vercel cron auth ───
# CRON_SECRET=your_cron_secret_here

# ─── Test/dev only — do NOT set in production ───
# ALLOW_TEST_CREDITS=true
# TEST_CREDIT_SECRET=your_test_secret
